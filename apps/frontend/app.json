{
  "expo": {
    "name": "Alethical",
    "slug": "alethical",
    "scheme": "alethical",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "description": "Plain-language legislative intelligence for people who care about what government is doing.",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f1e8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alethical.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.alethical"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Alethical",
      "shortName": "Alethical",
      "themeColor": "#111111",
      "backgroundColor": "#f5f1e8",
      "display": "standalone"
    },
    "plugins": [
      [
        "expo-web-browser",
        {
          "experimentalLauncherActivity": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "e9bfa83e-58af-44d9-8587-8207217bb836"
      }
    }
  }
}
