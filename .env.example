# ==============================================================================
# Alethical environment template
#
# Copy this file to `.env` at the repo root, then fill in the values marked
# "SET THIS". Everything else already has a working default and can be left as-is
# for local development.
#
#   cp .env.example .env
#
# The backend + ingestion pipeline auto-load `.env` from the repo root, and the
# Expo frontend reads the same file for its EXPO_PUBLIC_* values.
#
# NEVER commit your real `.env`. NEVER put a service-role / secret key in any
# EXPO_PUBLIC_* variable — those are bundled into the shipped client.
#
# Note: the government data sources (Revisor bills, legislator roster, chamber
# votes) are public and need NO environment variables at all. Only district
# lookup, OpenAI, Supabase auth, and map tiles read anything below.
# ==============================================================================

# ------------------------------------------------------------------------------
# Database (backend + pipeline)
# ------------------------------------------------------------------------------
# Local Docker Compose provides Postgres automatically (user/pass/db all
# "alethical", host port 54329). Only set DATABASE_URL if you run the backend
# OUTSIDE compose against that database:
# DATABASE_URL=postgresql+psycopg://alethical:alethical@localhost:54329/alethical

ALETHICAL_DATABASE_TARGET=local          # local | production (compose picks the DB URL)
# ALETHICAL_PIPELINE_TARGET=local        # default --target for the Oban pipeline CLI
# OBAN_DSN=                              # optional: separate DSN for the Oban job queue

# ------------------------------------------------------------------------------
# Supabase — auth (all environments) + production database
# From Supabase dashboard > Project Settings > API. Use the PUBLISHABLE/ANON key.
# ------------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx        # SET THIS (or SUPABASE_ANON_KEY below)
# SUPABASE_ANON_KEY=                                # legacy alias, accepted as a fallback

# Production database via the Supabase pooler (only when ALETHICAL_DATABASE_TARGET=production):
# SUPABASE_PROJECT_URL=https://your-project.supabase.co
# SUPABASE_PROJECT_REF=your-project-ref
# SUPABASE_DB_PASSWORD=                             # SET THIS for the production DB
# SUPABASE_POOLER_HOST=aws-1-us-east-2.pooler.supabase.com

# ------------------------------------------------------------------------------
# Local dev + internal auth
# ------------------------------------------------------------------------------
# Static bearer token that authenticates as a demo user WITHOUT Supabase.
# Convenient for local dev; leave UNSET in any shared/staging/production env
# (it is an authentication bypass).
ALETHICAL_DEV_AUTH_TOKEN=local-dev-token

# Guards the /internal/v1/* endpoints (ingestion status, Oban dashboard).
# The value below is the well-known default in code — OVERRIDE it with a strong
# secret in any deployed environment.
INTERNAL_API_TOKEN=dev-internal-token              # SET a strong value in production

# ------------------------------------------------------------------------------
# CORS + logging (backend)
# ------------------------------------------------------------------------------
ALETHICAL_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,http://127.0.0.1:19006
# ALETHICAL_LOG_LEVEL=INFO
# ALETHICAL_LOG_DIR=/app/logs
# ALETHICAL_SKIP_MIGRATIONS=            # set to 1 to skip alembic upgrade on container start

# ------------------------------------------------------------------------------
# OpenAI — AI bill summaries (Batch API) + RAG chat synthesis
# All government data ingestion works WITHOUT this key; only AI features need it.
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-xxx                              # SET THIS to enable AI features
OPENAI_AI_ENRICHMENT_MODEL=gpt-4o-mini
OPENAI_RAG_CHAT_MODEL=gpt-4o-mini

# ------------------------------------------------------------------------------
# District lookup — "Find My Legislator" (query-time)
# Public APIs with working defaults; override only to point at a mirror/mock.
# ------------------------------------------------------------------------------
ALETHICAL_CENSUS_GEOCODER_URL=https://geocoding.geo.census.gov/geocoder/locations/onelineaddress
ALETHICAL_CENSUS_BENCHMARK=Public_AR_Current
ALETHICAL_MN_GIS_LOOKUP_URL=https://gis.lcc.mn.gov/api/
ALETHICAL_HTTP_TIMEOUT_SECONDS=10

# ------------------------------------------------------------------------------
# Frontend (Expo) — EXPO_PUBLIC_* are bundled into the client: publishable only!
# ------------------------------------------------------------------------------
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx   # SET THIS (publishable only)

# Map tiles for the Find-My-Legislator map (OpenStreetMap defaults shown).
EXPO_PUBLIC_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
EXPO_PUBLIC_MAP_TILE_USER_AGENT="Alethical/0.1 (+https://alethical-web.vercel.app)"
# EXPO_PUBLIC_OPENSTREETMAP_TILE_URL=  # optional; takes precedence over EXPO_PUBLIC_MAP_TILE_URL

# ------------------------------------------------------------------------------
# Local dev port overrides (Docker Compose) — optional
# ------------------------------------------------------------------------------
# BACKEND_PORT=8000
# FRONTEND_PORT=19006
# DB_PORT=54329
