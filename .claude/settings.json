{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/block-sensitive-commit.sh\"",
            "timeout": 10,
            "statusMessage": "Leak-guard: checking staged files"
          }
        ]
      }
    ]
  }
}
