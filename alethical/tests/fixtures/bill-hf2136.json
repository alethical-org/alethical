  "bill_text": {
    "bill_title_text": "A bill for an act relating to children, youth, and families; appropriating money for grants for forensic interview training scholarships.",
    "page_title": "HF 2136 Introduction - 94th Legislature (2025 - 2026)",
    "sections": [
      {
        "heading": "Section 1. APPROPRIATIONS; FORENSIC INTERVIEW TRAINING SCHOLARSHIPS.",
        "section_id": "laws.0.1.0",
        "text": "$250,000 in fiscal year 2026 and $250,000 in fiscal year 2027 are appropriated from the general fund to the commissioner of children, youth, and families for grants to nationally recognized forensic interview protocol organizations to award scholarships for basic forensic interview training, advanced forensic interview training, and training on specialized interview topics. Scholarship recipients may include individuals in law enforcement, child protection, and prosecution; health professionals investigating, treating, and managing child maltreatment cases in Minnesota; and forensic interviewers at children's advocacy centers."
      }
    ],
